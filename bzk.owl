<?xml version="1.0"?>
<rdf:RDF xmlns="https://bzk.fiz-karlsruhe.de/ontology/"
     xml:base="https://bzk.fiz-karlsruhe.de/ontology/"
     xmlns:dce="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:ontology="https://nfdi.fiz-karlsruhe.de/ontology/">
    <owl:Ontology rdf:about="https://bzk.fiz-karlsruhe.de/ontology/">
        <owl:versionIRI rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/1.0.1"/>
        <dcterms:bibliographicCitation>BZKO Ontology. Version 1.0.1, https://bzk.fiz-karlsruhe.de/ontology/</dcterms:bibliographicCitation>
        <dcterms:created>2026-06-26</dcterms:created>
        <dcterms:description xml:lang="en">The BZK Ontology (BZKO) has been designed to semantically represent the content of the BZK index cards, a collection held in the German Federal Central Register (Bundeszentralkartei, abbreviated BZK). This central index card archive serves as an internal archival tool for tracking Wiedergutmachung records related to compensation and restitution for National Socialist injustice. BZKO aims to serve as the foundation for a knowledge graph that enables semantic search within Themenportal Wiedergutmachung, a central digital portal for the collection of Wiedergutmachung records.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0/"/>
        <dcterms:title>BZK Ontology</dcterms:title>
        <owl:versionInfo>1.0.1</owl:versionInfo>
    </owl:Ontology>
    


