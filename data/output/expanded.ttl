#    Annotations
#################################################################

<http://www.w3.org/ns/prov#hadPrimarySource> obo:IAO_0000116 """In the PROV-O documentation, it is understood that something that had a primary source is a derivation. That is also why the superrelation of \"had primary source\" is \"was derived from\". 
For instance, a chart had a primary source from a database, or a quotation was derived from a text.

In the PiCo documentation, it is used to relate \"Person Observation\" to \"Source\", where \"Source\" refers to the historical record or document where \"Person Observation\"s are found. Indeed, in PiCo, a source is any resource where a person is mentioned, including archival records, books, or personal documents, not just traditional archives. 

However, it is not a person observation but the name or address of a person observation recorded in a source. Similarly, a BZK number is on a BZK Index Card. Thereby, the domain of the prov:hadPrimarySource is the classes that are about Person Observation."""@en ;
                                             rdfs:label "hadPrimarySource" .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX applicant_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> 
PREFIX organization: <http://purl.obolibrary.org/obo/OBI_0000245>
PREFIX CO_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> 


PREFIX applies_for_compensation_to: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013>

CONSTRUCT { ?wgm_applicant1  applies_for_compensation_to: ?compen_office1}
WHERE {
   ?wgm_applicant1 a person: .
   ?applicant_role1 a applicant_role: .  
   ?indexing1 a indexing: .
   ?wgm_applicant1 has_role:  ?applicant_role1 .
   ?wgm_applicant1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?applicant_role1 .

   ?compen_office1 a organization: .
   ?CO_role1 a CO_role: .  
  ?compen_office1 has_role:  ?CO_role1 .
   ?compen_office1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?CO_role1 .
}""" ;
                                                    rdfs:label "applies for compensation to"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "An applicant applies for compensation for on behalf of a persecuted person to a compensation office."@en .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX applicant_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 

PREFIX applies_for_compensation_for: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016> 

CONSTRUCT { ?wgm_applicant1  applies_for_compensation_for: ?persecutee_nazi1}
WHERE {
   ?wgm_applicant1 a person: .
   ?applicant_role1 a applicant_role: .  
   ?wgm_applicant1 has_role:  ?applicant_role1 .
   ?indexing1 a indexing: .
   ?wgm_applicant1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?applicant_role1 .

   ?persecutee_nazi1 a person: .
   ?persecutee_role1 a persecutee_role: .  
   ?persecutee_nazi1 has_role:  ?persecutee_role1 .
   ?persecutee_nazi1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?persecutee_role1 .
}""" ;
                                                    rdfs:label "applies for compensation for"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "An applicant applies for compensation on behalf of at least one persecuted person."@en .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX denotes: <http://purl.obolibrary.org/obo/IAO_0000219>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_number: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003>

PREFIX has_bzk_number: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020> 

CONSTRUCT {
  ?bzk_card1 has_bzk_number: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_number1 a bzk_number: .
  ?bzk_number1 denotes: ?bzk_card1 .
  ?bzk_number1 labeled: ?label .
}""" ;
                                                    rdfs:label "has bzk number"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "A BZK index card includes a BZK number, a Federal Central Register number used to track compensation claims. This data property links a BZK card to its identifier." .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010024> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX organization: <http://purl.obolibrary.org/obo/OBI_0000245> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX realized_in: <http://purl.obolibrary.org/obo/BFO_0000054> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX CO_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> 
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> 

PREFIX issues: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010024> 

CONSTRUCT {?compen_office1 issues: ?bzk_card1 }  
WHERE {
   ?compen_office1 a organization: .
   ?indexing1 a indexing: .
   ?CO_role1 a CO_role: .
   ?bzk_card1 a bzk_card: .
   ?compen_office1 has_role:  ?CO_role1  .
   ?CO_role1 realized_in: ?indexing1 .
   ?compen_office1 participates_in: ?indexing1 .
   ?bzk_card1 participates_in: ?indexing1 .
}""" ;
                                                    rdfs:label "issues"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "A compensation office issues compensation-related documents, including BZK index cards."@en .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX lastResidentialAdd: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_last_residen_add: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025> 

CONSTRUCT { ?person1 has_last_residen_add: ?label}
WHERE {
?person1 a person: .
?lastResidentialAdd1 a lastResidentialAdd: .
?lastResidentialAdd1 is_about: ?person1 .
?lastResidentialAdd1 labeled: ?label .
}""" ;
                                                    rdfs:label "has last residential address"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This data property links a person to their last residential address before a specified event."@en .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010027> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX organization: <http://purl.obolibrary.org/obo/OBI_0000245> 
PREFIX compOffiName: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_compen_off_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010027> 
CONSTRUCT { ?compen_office1 has_compen_off_name: ?label}
WHERE {
   ?compen_office1 a organization: .
   ?compOffiName1 a compOffiName: .
   ?compen_office1 denotedBy: ?compOffiName1 .
   ?compOffiName1 labeled: ?label .
}""" ;
                                                    rdfs:label "has compensation office name"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This property links a compensation office to its name."@en .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010028> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX birthProcessBound: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008> 
PREFIX place: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>
PREFIX has_participant: <http://purl.obolibrary.org/obo/RO_0000057> 
PREFIX located_in: <http://purl.obolibrary.org/obo/RO_0001025>
PREFIX environs: <http://purl.obolibrary.org/obo/BFO_0000183>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_birthplace: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010028> 

CONSTRUCT { ?person1 has_birthplace: ?label}
WHERE {
?person1 a person: .
?birthProcessBound1 a birthProcessBound: .
?birthplace1 a place: .
?birthProcessBound1 has_participant: ?person1 .
?birthplace1 environs: ?birthProcessBound1 . 
?person1 located_in: ?birthplace1 .
?birthplace1 labeled: ?label .
}""" ;
                                                    rdfs:label "has birthplace"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This data property links a person to the place where they were born."@en .


<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010029> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX has_participant: <http://purl.obolibrary.org/obo/RO_0000057> 
PREFIX located_in: <http://purl.obolibrary.org/obo/RO_0001025>
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX deathProcessBound: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> 
PREFIX place: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>
PREFIX environs: <http://purl.obolibrary.org/obo/BFO_0000183>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_deathplace: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010029> 
CONSTRUCT { ?person1 has_deathplace: ?label}
WHERE {
?person1 a person: .
?deathProcessBound1 a deathProcessBound: .
?deathplace1 a place: .
?deathProcessBound1 has_participant: ?person1 .
?deathplace1 environs: ?deathProcessBound1 . 
?person1 located_in: ?deathplace1 .
?deathplace1 labeled: ?label .
}""" ;
                                                    rdfs:label "has deathplace"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This data property links a person to the place where they were died."@en .


<https://schema.org/birthDate> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX birthProcessBound: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008> 
PREFIX temporalInstant: <http://purl.obolibrary.org/obo/BFO_0000203>
PREFIX occup_temp_region: <http://purl.obolibrary.org/obo/BFO_0000199>
PREFIX has_participant: <http://purl.obolibrary.org/obo/RO_0000057> 
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX birthdate: <https://schema.org/birthDate> 

CONSTRUCT { ?person1 birthdate: ?label}
WHERE {
?person1 a person: .
?birthProcessBound1 a birthProcessBound: .
?dateOfBirth1 a temporalInstant: .
?birthProcessBound1 has_participant: ?person1 .
?birthProcessBound1 occup_temp_region: ?dateOfBirth1 .
?dateOfBirth1 labeled: ?label .
}""" ;
                               rdfs:comment "Date of birth."@en ;
                               rdfs:isDefinedBy <https://schema.org/birthDate> ;
                               rdfs:label "birthDate"@en .


<https://schema.org/deathDate> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX deathProcessBound: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> 
PREFIX temporalInstant: <http://purl.obolibrary.org/obo/BFO_0000203>
PREFIX occup_temp_region: <http://purl.obolibrary.org/obo/BFO_0000199>
PREFIX has_participant: <http://purl.obolibrary.org/obo/RO_0000057> 
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX deathdate: <https://schema.org/deathDate> 

CONSTRUCT { ?person1 deathdate: ?label}
WHERE {
?person1 a person: .
?deathProcessBound1 a deathProcessBound: .
?dateOfDeath1 a temporalInstant: .
?deathProcessBound1 has_participant: ?person1 .
?deathProcessBound1 occup_temp_region: ?dateOfDeath1 .
?dateOfDeath1 labeled: ?label .
}""" ;
                               rdfs:comment "Date of death."@en ;
                               rdfs:isDefinedBy <https://schema.org/deathDate> ;
                               rdfs:label "deathDate"@en .


<https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX digitBZKcard: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011>
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>

PREFIX hasOrHadDigitalInstantiation: <https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation>

CONSTRUCT {
  ?bzk_card1 hasOrHadDigitalInstantiation:  ?digitBZKcard1.
}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?digitBZKcard1 a digitBZKcard: .
  ?digitBZKcard1 is_about: ?bzk_card1 .
}""" ;
                                                                          rdfs:comment """Connects a record resource to one of its digital instantiations,
         whether it exists or has been lost or destroyed."""@en ;
                                                                          rdfs:label "a ou a eu pour instanciation numérique"@fr ,
                                                                                     "has or had digital instantiation"@en ,
                                                                                     "tiene o tenía como instanciación digital"@es .


<https://www.ica.org/standards/RiC/ontology#hasOrHadIdentifier> obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotes: <http://purl.obolibrary.org/obo/IAO_0000219>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_number: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003>

PREFIX hasOrHadIdentifier: <https://www.ica.org/standards/RiC/ontology#hasOrHadIdentifier> 

CONSTRUCT {
  ?bzk_card1 hasOrHadIdentifier: ?bzk_number1 .
}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_number1 a bzk_number: .
  ?bzk_number1 denotes: ?bzk_card1 .
}""" ;
                                                                rdfs:comment """Connects a Thing to one of its past or present
         Identifiers."""@en ;
                                                                rdfs:label "a ou a eu pour identifiant"@fr ,
                                                                           "has or had identifier"@en ,
                                                                           "tiene o tenía como identificador"@es .


