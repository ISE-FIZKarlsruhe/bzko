###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011
<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> rdf:type owl:Class ;
                                                    rdfs:subClassOf obo:IAO_0000310 ,
                                                                    <https://www.ica.org/standards/RiC/ontology#Instantiation> ,
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty obo:IAO_0000136 ;
                                                                      owl:someValuesFrom <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
                                                                    ] ;
                                                    rdfs:comment "All digitised BZK cards are digital versions of physical BZK Cards, but some BZK Cards may not have their scans in the database. For instance, the back of a BZK card may not have been scanned or linked to the front of the card."@en ;
                                                    rdfs:label "digitised bzk card"@en ;
