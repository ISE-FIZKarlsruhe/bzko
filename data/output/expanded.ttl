###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021
<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> ;
                                                    rdfs:range rdfs:Literal ;
                                                    obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX givenName: <http://purl.obolibrary.org/obo/IAO_0020016>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_given_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> 

CONSTRUCT { ?person1 has_given_name: ?label}
WHERE {
   ?person1 a person: .
   ?givenName1 a givenName: .
   ?person1 denotedBy: ?givenName1 .
   ?givenName1 labeled: ?label .
}""" ;
                                                    rdfs:label "has given name"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This data property links a person to their given (first) name."@en .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022
<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022> rdf:type owl:DatatypeProperty ;
                                                    rdfs:subPropertyOf <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> ;
                                                    rdfs:domain <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> ;
                                                    rdfs:range rdfs:Literal ;
                                                    obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX alterGivenName: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007>
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_alter_given_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022> 

CONSTRUCT { ?person1 has_alter_given_name: ?label}
WHERE {
   ?person1 a person: .
   ?alterGivenName1 a alterGivenName: .
   ?person1 denotedBy: ?alterGivenName1 .
   ?alterGivenName1 labeled: ?label .
}""" ;
                                                    rdfs:label "has alternative given name"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This data property links a person to an alternative given name." .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025
