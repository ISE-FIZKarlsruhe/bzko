                                                    rdfs:domain <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> ;
                                                    rdfs:range rdfs:Literal .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026
<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> ;
                                                    obo:OMO_0002000 """PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_layout: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004>
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>

PREFIX has_bzk_layout: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026>

CONSTRUCT {
  ?bzk_card1 has_bzk_layout: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_layout1 a bzk_layout: .
  ?bzk_layout1 is_about: ?bzk_card1 .
  ?bzk_layout1 labeled: ?label .
}""" ;
                                                    rdfs:label "has layout type"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "This data properry links a BZK index card to its layout type, which is determined by experts at the Federal State Archive."@en .


