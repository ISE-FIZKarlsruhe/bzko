AnnotationAssertion(rdfs:label <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> "place"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> "A site that refers to geographical locations, such as cities, countries, landmarks, and natural environments."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> "A spatial region, e.g. country, city or district."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> "Hessen, Berlin, Schweiz")
AnnotationAssertion(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0010013> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> "Issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/75")
SubClassOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> <http://purl.obolibrary.org/obo/BFO_0000029>)

