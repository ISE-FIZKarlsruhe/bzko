SubClassOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000203> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0000033> ObjectSomeValuesFrom(ObjectInverseOf(<http://purl.obolibrary.org/obo/RO_0002234>) <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000224>)))
