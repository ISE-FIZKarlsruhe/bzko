Prefix(:=<https://bzk.fiz-karlsruhe.de/ontology/>)
Prefix(dce:=<http://purl.org/dc/elements/1.1/>)
Prefix(obo:=<http://purl.obolibrary.org/obo/>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(dcterms:=<http://purl.org/dc/terms/>)


Ontology(<https://bzk.fiz-karlsruhe.de/ontology/extension>
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/components/imports-edit.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/components/rigid.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/imports/nfdicore_import.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/imports/pico_import.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/imports/prov_import.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/imports/rico_import.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/imports/ro_import.owl>)
Import(<https://bzk.fiz-karlsruhe.de/ontology/bzk/imports/schema_import.owl>)
Annotation(dcterms:description "None")
Annotation(dcterms:license <https://creativecommons.org/licenses/unspecified>)
Annotation(dcterms:title "BZK Ontology Extension")

Declaration(Class(:BZK_0000013))
Declaration(Class(:BZK_0010009))
Declaration(Class(:BZK_0010010))
Declaration(Class(:BZK_0010012))
Declaration(Class(:BZK_0010118))
Declaration(Class(:BZK_0010119))
Declaration(Class(:BZK_0023010))
Declaration(Class(:BZK_0023012))
Declaration(AnnotationProperty(dcterms:description))
Declaration(AnnotationProperty(dcterms:license))
Declaration(AnnotationProperty(dcterms:title))
############################
#   Annotation Properties
############################

# Annotation Property: dcterms:description (description)

AnnotationAssertion(rdfs:label dcterms:description "description")

# Annotation Property: dcterms:license (license)

AnnotationAssertion(rdfs:label dcterms:license "license")

# Annotation Property: dcterms:title (title)

AnnotationAssertion(rdfs:label dcterms:title "title")


############################
#   Object Properties
############################

# Object Property: <http://www.w3.org/ns/prov#hadPrimarySource> (hadPrimarySource)

AnnotationAssertion(obo:IAO_0000116 <http://www.w3.org/ns/prov#hadPrimarySource> "In the PROV-O documentation, it is understood that something that had a primary source is a derivation. That is also why the superrelation of \"had primary source\" is \"was derived from\". 
For instance, a chart had a primary source from a database, or a quotation was derived from a text.

In the PiCo documentation, it is used to relate \"Person Observation\" to \"Source\", where \"Source\" refers to the historical record or document where \"Person Observation\"s are found. Indeed, in PiCo, a source is any resource where a person is mentioned, including archival records, books, or personal documents, not just traditional archives. 

However, it is not a person observation but the name or address of a person observation recorded in a source. Similarly, a BZK number is on a BZK Index Card. Thereby, the domain of the prov:hadPrimarySource is the classes that are about Person Observation."@en)
ObjectPropertyRange(<http://www.w3.org/ns/prov#hadPrimarySource> :BZK_0010011)

# Object Property: <https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation> (has or had digital instantiation)

AnnotationAssertion(obo:OMO_0002000 <https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation> "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX digitBZKcard: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011>
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>

PREFIX hasOrHadDigitalInstantiation: <https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation>

CONSTRUCT {
  ?bzk_card1 hasOrHadDigitalInstantiation:  ?digitBZKcard1.
}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?digitBZKcard1 a digitBZKcard: .
  ?digitBZKcard1 is_about: ?bzk_card1 .
}")

# Object Property: <https://www.ica.org/standards/RiC/ontology#hasOrHadIdentifier> (tiene o tenía como identificador)

AnnotationAssertion(obo:OMO_0002000 <https://www.ica.org/standards/RiC/ontology#hasOrHadIdentifier> "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotes: <http://purl.obolibrary.org/obo/IAO_0000219>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_number: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003>

PREFIX hasOrHadIdentifier: <https://www.ica.org/standards/RiC/ontology#hasOrHadIdentifier> 

CONSTRUCT {
  ?bzk_card1 hasOrHadIdentifier: ?bzk_number1 .
}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_number1 a bzk_number: .
  ?bzk_number1 denotes: ?bzk_card1 .
}")



############################
#   Classes
############################

# Class: :BZK_0000002 (bzk card)

SubClassOf(:BZK_0000002 <https://www.ica.org/standards/RiC/ontology#Record>)
SubClassOf(:BZK_0000002 ObjectSomeValuesFrom(<https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation> :BZK_0010011))
SubClassOf(:BZK_0000002 ObjectSomeValuesFrom(<https://www.ica.org/standards/RiC/ontology#hasOrHadIdentifier> :BZK_0000003))

# Class: :BZK_0000013 (wgm applicant)

AnnotationAssertion(obo:IAO_0000116 :BZK_0000013 "The name of a BZK applicant can occur on diffent cards.
A BZK applicant can be a persecutee at the same time.")
AnnotationAssertion(rdfs:label :BZK_0000013 "wgm applicant"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0000013 "A WGM applicant is a person who was recorded as an applicant on a BZK card and applies for compensation as a persecuted person.")
EquivalentClasses(:BZK_0000013 ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> ObjectSomeValuesFrom(obo:RO_0000087 :BZK_0010003)))
SubClassOf(:BZK_0000013 <https://personsincontext.org/model#PersonObservation>)
SubClassOf(:BZK_0000013 ObjectSomeValuesFrom(:BZK_0010013 :BZK_0010012))

# Class: :BZK_0010010 (persecutee of the nazi regimee)

AnnotationAssertion(rdfs:label :BZK_0010010 "persecutee of the nazi regimee"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010010 "A person who was subjected to persecution by the Nazi regimee, including but not limited to discrimination, dispossession, forced displacement, or violence, on political, racial, religious, or other grounds."@en)
EquivalentClasses(:BZK_0010010 ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> ObjectSomeValuesFrom(obo:RO_0000087 :BZK_0010002)))
SubClassOf(:BZK_0010010 <https://personsincontext.org/model#PersonObservation>)

# Class: :BZK_0010012 (compensation office)

AnnotationAssertion(rdfs:label :BZK_0010012 "compensation office"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010012 "A compensation office is a government agency that reviews claims and provides compensation to persecuted people."@en)
EquivalentClasses(:BZK_0010012 ObjectIntersectionOf(obo:OBI_0000245 ObjectSomeValuesFrom(obo:RO_0000087 :BZK_0010001)))
SubClassOf(:BZK_0010012 ObjectSomeValuesFrom(:BZK_0010024 :BZK_0000002))
SubClassOf(:BZK_0010012 ObjectAllValuesFrom(obo:IAO_0000235 :BZK_0010005))

# Class: :BZK_0010118 (birthplace)

AnnotationAssertion(rdfs:label :BZK_0010118 "birthplace"@en)
EquivalentClasses(:BZK_0010118 ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> ObjectSomeValuesFrom(obo:BFO_0000183 :BZK_0010008)))
SubClassOf(:BZK_0010118 <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>)

# Class: :BZK_0010119 (deathplace)

AnnotationAssertion(rdfs:label :BZK_0010119 "deathplace"@en)
EquivalentClasses(:BZK_0010119 ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005> ObjectSomeValuesFrom(obo:BFO_0000183 :BZK_0010009)))
SubClassOf(:BZK_0010119 <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>)

# Class: :BZK_0023010 (date of birth)

AnnotationAssertion(rdfs:label :BZK_0023010 "date of birth"@en)
EquivalentClasses(:BZK_0023010 ObjectIntersectionOf(obo:BFO_0000203 ObjectSomeValuesFrom(ObjectInverseOf(obo:BFO_0000199) :BZK_0010008)))
SubClassOf(:BZK_0023010 obo:BFO_0000203)

# Class: :BZK_0023012 (date of death)

AnnotationAssertion(rdfs:label :BZK_0023012 "date of death"@en)
EquivalentClasses(:BZK_0023012 ObjectIntersectionOf(obo:BFO_0000203 ObjectSomeValuesFrom(ObjectInverseOf(obo:BFO_0000199) :BZK_0010009)))
SubClassOf(:BZK_0023012 obo:BFO_0000203)


AnnotationAssertion(rdfs:comment <https://personsincontext.org/model#eventPlace> "This data property can be used for death place and birth place."@en)
AnnotationAssertion(obo:OMO_0002000 <https://schema.org/deathDate> "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX has_participant: <http://purl.obolibrary.org/obo/RO_0000057> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX located_in <http://purl.obolibrary.org/obo/RO_0001025>
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 
PREFIX deathProcessBound: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> 
PREFIX occup_temp_region: <http://purl.obolibrary.org/obo/BFO_0000199>
PREFIX temp_instant: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0023012>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX deathdate: <https://schema.org/deathDate> 

CONSTRUCT { ?persecutee_nazi1 deathdate: ?label}
WHERE {
?persecutee_nazi1 a person: .
?persecutee_role1 a persecutee_role: . 
?indexing1 a indexing: . 

?persecutee_nazi1 has_role:  ?persecutee_role1 .
?persecutee_nazi1 participates_in: ?indexing1 .
?indexing1 realizes: ?persecutee_role1 .

?deathProcessBound1 a deathProcessBound: .
?deathProcessBound1 has_participant: ?persecutee_nazi1 .

?dateOfDeath1 a temp_instant: .
?deathProcessBound1 occup_temp_region: ?dateOfDeath1 .
?dateOfDeath1 labeled: ?label: .

}")
)