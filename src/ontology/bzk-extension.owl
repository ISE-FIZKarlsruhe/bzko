#   Object Properties
############################

# Object Property: :BZK_0010013 (applies for compensation to)

AnnotationAssertion(rdfs:comment :BZK_0010013 "The domain must include both applicant and persecutee. Is it possible to define the domain by \"person observation\"?")
AnnotationAssertion(rdfs:label :BZK_0010013 "applies for compensation to"@en)
ObjectPropertyDomain(:BZK_0010013 <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004>)
ObjectPropertyRange(:BZK_0010013 :BZK_0010012)

# Object Property: :BZK_0010014 (is applied for compensation by)

AnnotationAssertion(rdfs:label :BZK_0010014 "is applied for compensation by"@en)
ObjectPropertyDomain(:BZK_0010014 :BZK_0010010)
ObjectPropertyRange(:BZK_0010014 :BZK_0010009)

# Object Property: :BZK_0010015 (has layout type)

AnnotationAssertion(rdfs:label :BZK_0010015 "has layout type"@en)
InverseObjectProperties(:BZK_0010015 :BZK_0010017)
ObjectPropertyDomain(:BZK_0010015 :BZK_0000002)
ObjectPropertyRange(:BZK_0010015 :BZK_0010004)

# Object Property: :BZK_0010016 (applies for compensation of)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010016 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX bzk_process: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX applicant_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 

prefix applies_for_compensation_of: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016> 

CONSTRUCT { ?applicant  applies_for_compensation_of: ?persecutee } where {
   ?applicant a person: .
   ?applicant has_role:  ?app_role .
   ?app_role a applicant_role: .  
   ?applicant participates_in: ?proc .
   ?proc a bzk_process: .
   ?proc realizes: ?app_role .

   ?persecutee a person: .
   ?persecutee has_role:  ?pers_role .
   ?pers_role a persecutee_role: .  
   ?persecutee participates_in: ?proc .
   ?proc realizes: ?persecutee_role .
}")
AnnotationAssertion(rdfs:label :BZK_0010016 "applies for compensation of"@en)
ObjectPropertyDomain(:BZK_0010016 :BZK_0000013)
ObjectPropertyRange(:BZK_0010016 :BZK_0010010)

# Object Property: :BZK_0010017 (is layout type of)

AnnotationAssertion(rdfs:label :BZK_0010017 "is layout type of"@en)
ObjectPropertyDomain(:BZK_0010017 :BZK_0010004)
ObjectPropertyRange(:BZK_0010017 :BZK_0000002)

# Object Property: :BZK_0010024 (issues)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010024 "prefix owl: <http://www.w3.org/2002/07/owl#> 
prefix organization: <http://purl.obolibrary.org/obo/OBI_0000245> 
prefix bzk_process: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
prefix has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
prefix realized_in: <http://purl.obolibrary.org/obo/BFO_0000054> 
prefix participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
prefix office_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> 
prefix card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> 

prefix issues: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010024> 

construct {?organization issues: ?card }  where {
   ?organization a organization: .
   ?proc a bzk_process: .
   ?organization has_role:  ?r  .
   ?r a office_role: .
   ?r realized_in: ?proc .
   ?organization participates_in: ?proc .
   ?card a card: .
   ?card participates_in: ?proc .
}")
AnnotationAssertion(rdfs:label :BZK_0010024 "issues"@en)
ObjectPropertyDomain(:BZK_0010024 :BZK_0010012)
ObjectPropertyRange(:BZK_0010024 :BZK_0000002)



