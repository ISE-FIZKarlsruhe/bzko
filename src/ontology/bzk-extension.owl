# Object Property: <http://www.w3.org/ns/prov#hadPrimarySource> (hadPrimarySource)

AnnotationAssertion(obo:IAO_0000116 <http://www.w3.org/ns/prov#hadPrimarySource> "In the PROV-O documentation, it is understood that something that had a primary source is a derivation. That is also why the superrelation of \"had primary source\" is \"was derived from\". 
For instance, a chart had a primary source from a database, or a quotation was derived from a text.

In the PiCo documentation, it is used to relate \"Person Observation\" to \"Source\", where \"Source\" refers to the historical record or document where \"Person Observation\"s are found. Indeed, in PiCo, a source is any resource where a person is mentioned, including archival records, books, or personal documents, not just traditional archives. 

However, it is not a person observation but the name or address of a person observation recorded in a source. Similarly, a BZK number is on a BZK Index Card. Thereby, the domain of the prov:hadPrimarySource is the classes that are about Person Observation."@en)
ObjectPropertyRange(<http://www.w3.org/ns/prov#hadPrimarySource> :BZK_0010011)

# Object Property: :BZK_0010013 (applies for compensation to)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010013 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX applicant_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> 
PREFIX organization: <http://purl.obolibrary.org/obo/OBI_0000245>
PREFIX CO_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> 


PREFIX applies_for_compensation_to: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013>

CONSTRUCT { ?wgm_applicant  applies_for_compensation_to: ?compen_office} 
where {
   ?wgm_applicant a person: .
   ?wgm_applicant has_role:  ?app_role .
   ?app_role a applicant_role: .  
   ?wgm_applicant participates_in: ?indexing1 .
   ?indexing1 a indexing: .
   ?indexing1 realizes: ?app_role .

   ?compen_office a organization: .
  ?compen_office has_role:  ?CO_role1 .
   ?CO_role1 a CO_role: .  
   ?compen_office participates_in: ?indexing1 .
   ?indexing1 realizes: ?CO_role .
}")
AnnotationAssertion(rdfs:label :BZK_0010013 "applies for compensation to"@en)
ObjectPropertyDomain(:BZK_0010013 :BZK_0000013)
ObjectPropertyRange(:BZK_0010013 :BZK_0010012)

# Object Property: :BZK_0010014 (is applied for compensation by)

AnnotationAssertion(rdfs:label :BZK_0010014 "is applied for compensation by"@en)
InverseObjectProperties(:BZK_0010014 :BZK_0010016)
ObjectPropertyDomain(:BZK_0010014 :BZK_0010010)
ObjectPropertyRange(:BZK_0010014 :BZK_0010009)

# Object Property: :BZK_0010015 (has layout type)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010015 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_layout: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004>
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>

PREFIX has_bzk_layout: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010015>

CONSTRUCT {
  ?bzk_card1 has_bzk_layout: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_layout1 a bzk_layout: .
  ?bzk_layout1 is_about: ?bzk_card1 .
  ?bzk_layout1 labeled: ?label .
}")
AnnotationAssertion(rdfs:label :BZK_0010015 "has layout type"@en)
InverseObjectProperties(:BZK_0010015 :BZK_0010017)
ObjectPropertyDomain(:BZK_0010015 :BZK_0000002)
ObjectPropertyRange(:BZK_0010015 :BZK_0010004)

# Object Property: :BZK_0010016 (applies for compensation for)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010016 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX applicant_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 

PREFIX applies_for_compensation_for: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016> 

CONSTRUCT { ?wgm_applicant  applies_for_compensation_for: ?persecutee_nazi}
WHERE {
   ?wgm_applicant a person: .
   ?wgm_applicant has_role:  ?app_role .
   ?app_role a applicant_role: .  
   ?wgm_applicant participates_in: ?indexing1 .
   ?indexing1 a indexing: .
   ?indexing1 realizes: ?app_role .

   ?persecutee_nazi a person: .
   ?persecutee_nazi has_role:  ?pers_role .
   ?pers_role a persecutee_role: .  
   ?persecutee_nazi participates_in: ?indexing1 .
   ?indexing1 realizes: ?persecutee_role .
}")
AnnotationAssertion(rdfs:label :BZK_0010016 "applies for compensation for"@en)
ObjectPropertyDomain(:BZK_0010016 :BZK_0000013)
ObjectPropertyRange(:BZK_0010016 :BZK_0010010)

# Object Property: :BZK_0010017 (is layout type of)

AnnotationAssertion(rdfs:label :BZK_0010017 "is layout type of"@en)
ObjectPropertyDomain(:BZK_0010017 :BZK_0010004)
ObjectPropertyRange(:BZK_0010017 :BZK_0000002)

# Object Property: :BZK_0010018 (has given name)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010018 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX wgm_applicant: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013>
PREFIX persecutee_nazi: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010>
PREFIX givenName: <http://purl.obolibrary.org/obo/IAO_0020016>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_given_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010018> 

CONSTRUCT { ?wgm_agent has_given_name: ?label}
WHERE {
   ?wgm_agent a wgm_applicant: |  persecutee_nazi: .
   ?givenName1 a givenName: .
   ?wgm_agent denotedBy: ?givenName1: .
   ?givenName1 labeled: ?label: .
}")
AnnotationAssertion(rdfs:label :BZK_0010018 "has given name"@en)
ObjectPropertyDomain(:BZK_0010018 ObjectUnionOf(:BZK_0000013 :BZK_0010010))

# Object Property: :BZK_0010019 (has alternative given name)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010019 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX wgm_applicant: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013>
PREFIX persecutee_nazi: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010>
PREFIX alterGivenName: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_alter_given_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010019> 

CONSTRUCT { ?wgm_agent has_alter_given_name:: ?label}
WHERE {
   ?wgm_agent a wgm_applicant: |  persecutee_nazi: .
   ?alterGivenName1 a alterGivenName: .
   ?wgm_agent denotedBy: ?alterGivenName1: .
   ?alterGivenName1 labeled: ?label: .
}")
AnnotationAssertion(rdfs:label :BZK_0010019 "has alternative given name"@en)
SubObjectPropertyOf(:BZK_0010019 :BZK_0010018)

