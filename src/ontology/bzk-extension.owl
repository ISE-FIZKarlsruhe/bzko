AnnotationAssertion(obo:OMO_0002000 :BZK_0010023 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>
PREFIX persecutee_nazi: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010>
