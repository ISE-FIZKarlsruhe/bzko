# Class: obo:IAO_0020016 (given name)

AnnotationAssertion(rdfs:comment obo:IAO_0020016 "\"personal name\", the parent class of \"given name\", is not included in the ontology, because it is ambigious whether a given name is a part of a personal name, or a subclass of it. An issue will be created for this in the IAO GitHub repository.")
SubClassOf(obo:IAO_0020016 ObjectSomeValuesFrom(obo:IAO_0000136 <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004>))

# Class: obo:IAO_0020017 (family name)

SubClassOf(obo:IAO_0020017 ObjectSomeValuesFrom(obo:IAO_0000136 <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> (bzk card)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> "A BZK card is a physical card that is stored in an archive."@en)
AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> "All digitised BZK cards are digital versions of physical BZK Cards, but some BZK Cards may not have their scans in the database. For instance, the back of a BZK card may not have been scanned or linked to the front of the card."@en)
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> "bzk card"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> "A BZK Index Card, or simply a BZK Card, is a document used to initiate the compensation process."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002> obo:BFO_0000030)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> (bzk number)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> "A BZK number can be modelled as a part of a digitised BZK card. However, in some layout types, the BZK number appears in one of the textual parts instead of at the top-right of the card.")
AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> "A BZK number is not unique, viz., the same number can occur on different BZK Cards issued by different compensation offices."@en)
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> "bzk number"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> "A BZK number is an identifier for a BZK Card, which is a Federal Central Register number used for compensation claims."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> obo:IAO_0020000)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003> ObjectSomeValuesFrom(obo:IAO_0000136 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006> (birth name)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006> "birth name"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006> "A birth name is a family name that a woman had before marriage."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006> obo:IAO_0020017)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000007> (alternative last name)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000007> "In BZKO, an alternative last name can happen in two ways: the family name was changed to a German or Latin form, or the person changed their family name.")
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000007> "alternative last name"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000007> obo:IAO_0020017)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000014> (street name)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000014> "street name"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000014> obo:IAO_0020000)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000015> (house number)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000015> "house number"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000015> obo:IAO_0020000)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000016> (unit number)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000016> "unit number"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000016> obo:IAO_0020000)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000017> (postal code)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000017> "http://purl.obolibrary.org/obo/IAO_0000646 #postal code")
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000017> "postal code"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0000017> obo:IAO_0020000)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> (compensation process)

AnnotationAssertion(obo:IAO_0000116 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> "the compensation application process")
AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> "At the end of a BZK process, a BZK Index card is created by a compensation office for a persecuted person."@en)
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> "compensation process"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> "A process in which a person applies to a compensation office for themselves or on behalf of persecuted people."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> obo:BFO_0000015)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> ObjectSomeValuesFrom(obo:RO_0000057 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>))
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000> ObjectSomeValuesFrom(obo:RO_0000059 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> (compensation office role)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> "compensation office role"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> "A BZK compensation office role is inherited by governmental offices, which is realised when a BZK applicant applies for compensation for at least one persecuted person and the office claims a BZK card."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229>)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> ObjectSomeValuesFrom(obo:BFO_0000054 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> (persecutee role)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> "persecutee role"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> "A person who has a persecutee role is oppressed, harassed, or maltreated because of their gender, race, religion, or beliefs."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229>)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> ObjectSomeValuesFrom(obo:BFO_0000054 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> (applicant role)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> "applicant role"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> "A person who has an applicant role applies to an organisation for themselves or for another person."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229>)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> ObjectSomeValuesFrom(obo:BFO_0000054 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004> (bzk card layout)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004> "bzk card layout"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004> "A BZK card layout refers to the pattern in which the components of a BZK card are arranged or grouped."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004> obo:BFO_0000031)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005> (compensation office name)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005> "institutional identification can be a sublass of iao:identifier. the documentation will be read.")
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005> "compensation office name"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005> "A textual entity intended to identify a particular compensation office"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005> obo:IAO_0000303)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006> (last residential address)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006> "TODO: A BZK current address can only belong to persons who are alive at the time of the BZK process."@en)
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006> "last residential address"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006> "In this context, a BZK current address is the postal address of a BZK applicant or persecutee at the time of their compensation application."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006> obo:IAO_0000422)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007> (alternative first name)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007> "In BZKO, an alternative first name can happen in two ways: the name was changed to a German or Latin form, or the person changed their first name."@en)
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007> "alternative first name"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007> obo:IAO_0020016)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008> (birth process boundary)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008> "birth process boundary"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008> obo:BFO_0000035)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> (death process boundary)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> "death process boundary"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> obo:BFO_0000035)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> (digitised bzk card)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> "All digitised BZK cards are digital versions of physical BZK Cards, but some BZK Cards may not have their scans in the database. For instance, the back of a BZK card may not have been scanned or linked to the front of the card."@en)
AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> "Use rico:Instantiation in the mapping")
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> "digitised bzk card"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> "A digitised BZK Card refers to a scanned version of the corresponding physical BZK card."@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000022>)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011> ObjectSomeValuesFrom(obo:IAO_0000136 <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>))

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020> (neighborhood)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020> "neighborhood"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> (district)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> "district"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022> (region)

AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022> "region"@en)
SubClassOf(<https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>)

# Class: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010023> (compound)

AnnotationAssertion(rdfs:comment <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010023> "Examples include concentration camps, prisons and prison camps, refugee camps, and military bases."@en)
AnnotationAssertion(rdfs:label <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010023> "compound"@en)
AnnotationAssertion(skos:definition <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010023> "A settlement that does not fit the description of any administrative unit."@en)
