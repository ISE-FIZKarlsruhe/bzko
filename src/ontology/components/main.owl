        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:allValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">In BZKO, we restrict this process to the class &quot;bzk persecutee&quot; only.</rdfs:comment>
        <rdfs:label xml:lang="en">death process</rdfs:label>
    </owl:Class>
    


