    <!-- http://purl.obolibrary.org/obo/IAO_0020015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0020015">
        <rdfs:comment xml:lang="en">A given (first) and family (last) names are parts of a personal name.</rdfs:comment>
        <rdfs:comment xml:lang="en">In our ontology, a personal name is the full name of a person, consisting of a given name and familiy name, and sometimes also birth name.</rdfs:comment>
        <rdfs:comment xml:lang="en">TODO
equivalent to pnv:literal name</rdfs:comment>
    </owl:Class>
    


