    <!-- http://purl.obolibrary.org/obo/OBI_0000245 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000245"/>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#Record"/>
        <rdfs:comment xml:lang="en">A BZK card is a physical card that is stored in an archive.</rdfs:comment>
        <rdfs:comment xml:lang="en">All digitised BZK cards are digital versions of physical BZK Cards, but some BZK Cards may not have their scans in the database. For instance, the back of a BZK card may not have been scanned or linked to the front of the card.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk card</rdfs:label>
        <skos:definition xml:lang="en">A BZK Index Card, or simply a BZK Card, is a document used to initiate the compensation process.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:comment>A BZK number can be modelled as a part of a digitised BZK card. However, in some layout types, the BZK number appears in one of the textual parts instead of at the top-right of the card.</rdfs:comment>
        <rdfs:comment xml:lang="en">A BZK number is not unique, viz., the same number can occur on different BZK Cards issued by different compensation offices.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk number</rdfs:label>
        <skos:definition xml:lang="en">A BZK number is an identifier for a BZK Card, which is a Federal Central Register number used for compensation claims.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020017"/>
        <rdfs:label xml:lang="en">birth name</rdfs:label>
        <skos:definition xml:lang="en">A birth name is a family name that a woman had before marriage.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000007 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020017"/>
        <rdfs:comment>In BZKO, an alternative last name can happen in two ways: the family name was changed to a German or Latin form, or the person changed their family name.</rdfs:comment>
        <rdfs:label xml:lang="en">alternative last name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000008 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000008">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010018"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:OMO_0002000>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt;
PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
PREFIX xsd: &lt;http://www.w3.org/2001/XMLSchema#&gt;
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX has_participant: &lt;http://purl.obolibrary.org/obo/RO_0000057&gt;
PREFIX environs: &lt;http://purl.obolibrary.org/obo/BFO_0000183&gt; 
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt;
PREFIX death_place_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000008&gt;
PREFIX has_value: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001007&gt; 

CONSTRUCT {  ?p &lt;https://schema.org/deathPlace&gt;  ?label }
 WHERE { 
?p a  person: .
?proc has_participant: ?p. 
?loc environs: ?proc .
?loc has_role: ?role .
?role a  death_place_role: .
?loc has_value: ?label .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">death place role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000009 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000009">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010019"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:OMO_0002000>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt;
PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
PREFIX xsd: &lt;http://www.w3.org/2001/XMLSchema#&gt;
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX has_participant: &lt;http://purl.obolibrary.org/obo/RO_0000057&gt;
PREFIX environs: &lt;http://purl.obolibrary.org/obo/BFO_0000183&gt; 
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt;
PREFIX birth_place_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000009&gt;
PREFIX has_value: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001007&gt; 

CONSTRUCT {  ?p &lt;https://schema.org/birthPlace&gt;  ?label }
 WHERE { 
?p a  person: .
?proc has_participant: ?p. 
?loc environs: ?proc .
?loc has_role: ?role .
?role a  birth_place_role: .
?loc has_value: ?label .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">birth place role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009"/>
                            <rdf:Description rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000059"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">At the end of a BZK process, a BZK Index card is created by a compensation office for a persecuted person.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk process</rdfs:label>
        <skos:definition xml:lang="en">A process in which a person applies to a compensation office for themselves or on behalf of persecuted people.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001">
        <rdfs:subClassOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compensation office role</rdfs:label>
        <skos:definition xml:lang="en">A BZK compensation office role is inherited by governmental offices, which is realised when a BZK applicant applies for compensation for at least one persecuted person and the office claims a BZK card.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002">
        <rdfs:subClassOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">persecutee role</rdfs:label>
        <skos:definition xml:lang="en">A person who has a persecutee role is oppressed, harassed, or maltreated because of their gender, race, religion, or beliefs.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003">
        <rdfs:subClassOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">applicant role</rdfs:label>
        <skos:definition xml:lang="en">A person who has an applicant role applies to an organisation for themselves or for another person.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">bzk card layout</rdfs:label>
        <skos:definition xml:lang="en">A BZK card layout refers to the pattern in which the components of a BZK card are arranged or grouped.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000303"/>
        <rdfs:label xml:lang="en">compensation office name</rdfs:label>
        <skos:definition xml:lang="en">A textual entity intended to identify a particular compensation office</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000422"/>
        <rdfs:label xml:lang="en">bzk current address</rdfs:label>
        <skos:definition xml:lang="en">In this context, a BZK current address is the postal address of a BZK applicant or persecutee at the time of their compensation application.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020016"/>
        <rdfs:comment xml:lang="en">In BZKO, an alternative first name can happen in two ways: the name was changed to a German or Latin form, or the person changed their first name.</rdfs:comment>
        <rdfs:label xml:lang="en">alternative first name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008">
        <rdfs:subClassOf rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006"/>
        <rdfs:comment xml:lang="en">In BZKO, an alternative birth name is a German or Latin form of the family name in the original language.</rdfs:comment>
        <rdfs:label xml:lang="en">alternative birth name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009">
        <rdfs:subClassOf rdf:resource="https://personsincontext.org/model#PersonObservation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A BZK applicant can be a persecutee at the same time.</rdfs:comment>
        <rdfs:comment xml:lang="en">The name of a BZK applicant can occur on diffent cards.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk applicant</rdfs:label>
        <skos:definition xml:lang="en">A BZK applicant is a person who was recorded as an applicant on a BZK card and applies for compensation as a persecuted person.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010">
        <rdfs:subClassOf rdf:resource="https://personsincontext.org/model#PersonObservation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010014"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bzk persecutee</rdfs:label>
        <skos:definition xml:lang="en">A BZK persecutee is a person who was recorded as a persecutee on a BZK card.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009"/>
                            <rdf:Description rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">All digitised BZK cards are digital versions of physical BZK Cards, but some BZK Cards may not have their scans in the database. For instance, the back of a BZK card may not have been scanned or linked to the front of the card.</rdfs:comment>
        <rdfs:label xml:lang="en">digitised bzk card</rdfs:label>
        <skos:definition xml:lang="en">A digitised BZK Card refers to a scanned version of the corresponding physical BZK card.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000245"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000235"/>
                <owl:allValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compensation office</rdfs:label>
        <skos:definition xml:lang="en">A compensation office is a government agency that reviews claims and provides compensation to persecuted people.</skos:definition>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010018 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010018">
