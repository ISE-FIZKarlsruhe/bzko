        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020017"/>
        <rdfs:comment>In BZKO, an alternative last name can happen in two ways: the family name was changed to a German or Latin form, or the person changed their family name.</rdfs:comment>
        <rdfs:label xml:lang="en">alternative last name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000008 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000008">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:OMO_0002000>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt;
PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
PREFIX xsd: &lt;http://www.w3.org/2001/XMLSchema#&gt;
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX has_participant: &lt;http://purl.obolibrary.org/obo/RO_0000057&gt;
PREFIX environs: &lt;http://purl.obolibrary.org/obo/BFO_0000183&gt; 
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt;
PREFIX death_place_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000008&gt;
PREFIX has_value: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001007&gt; 

CONSTRUCT {  ?p &lt;https://schema.org/deathPlace&gt;  ?label }
 WHERE { 
?p a  person: .
?proc has_participant: ?p. 
?loc environs: ?proc .
?loc has_role: ?role .
?role a  death_place_role: .
?loc has_value: ?label .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">death place role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000009 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000009">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:OMO_0002000>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt;
PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
PREFIX xsd: &lt;http://www.w3.org/2001/XMLSchema#&gt;
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX has_participant: &lt;http://purl.obolibrary.org/obo/RO_0000057&gt;
PREFIX environs: &lt;http://purl.obolibrary.org/obo/BFO_0000183&gt; 
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt;
PREFIX birth_place_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000009&gt;
PREFIX has_value: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001007&gt; 

CONSTRUCT {  ?p &lt;https://schema.org/birthPlace&gt;  ?label }
 WHERE { 
?p a  person: .
?proc has_participant: ?p. 
?loc environs: ?proc .
?loc has_role: ?role .
?role a  birth_place_role: .
?loc has_value: ?label .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">birth place role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009"/>
                            <rdf:Description rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">TODO: move to skos:definition

A BZK process is a process in which a person applies to a compensation office for themselves or on behalf of persecuted people.</rdfs:comment>
        <rdfs:comment>At the end of a BZK process, a BZK Index card is created by a compensation office for a persecuted person.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk process</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001">
        <rdfs:subClassOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
        <rdfs:comment xml:lang="en">TODO move to skos:definition

A BZK compensation office role is inherited by governmental offices, which is realised when a BZK applicant applies for compensation for at least one persecuted person and the office claims a BZK card.</rdfs:comment>
        <rdfs:label xml:lang="en">compensation office role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002">
        <rdfs:subClassOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229"/>
        <rdfs:comment>TODO: move to skos:defintion

A person who has a persecutee role is oppressed, harassed, or maltreated because of their gender, race, religion, or beliefs.</rdfs:comment>
        <rdfs:label xml:lang="en">persecutee role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000245"/>
        <rdfs:comment xml:lang="en">TODO: move skos:definition
A person who has an applicant role applies to an organisation for themselves or for another person.</rdfs:comment>
        <rdfs:label xml:lang="en">applicant role</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:comment>TODO: move to skos:defintion

A BZK card layout refers to the pattern in which the components of a BZK card are arranged or grouped.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk card layout</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000303"/>
        <rdfs:label xml:lang="en">compensation office name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000422"/>
        <rdfs:comment xml:lang="en">TODO: move to skos: definition

In this context, a BZK current address is the postal address of a BZK applicant or persecutee at the time of their compensation application.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk current address</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020016"/>
        <rdfs:comment xml:lang="en">In BZKO, an alternative first name can happen in two ways: the name was changed to a German or Latin form, or the person changed their first name.</rdfs:comment>
        <rdfs:label xml:lang="en">alternative first name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008">
        <rdfs:subClassOf rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006"/>
        <rdfs:comment xml:lang="en">In BZKO, an alternative birth name is a German or Latin form of the family name in the original language.</rdfs:comment>
        <rdfs:label xml:lang="en">alternative birth name</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009">
        <rdfs:subClassOf rdf:resource="https://personsincontext.org/model#PersonObservation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A BZK applicant can be a persecutee at the same time.</rdfs:comment>
        <rdfs:comment xml:lang="en">TODO: move to skos:definition

A BZK applicant is a person who was recorded as an applicant on a BZK card and applies for compensation for a persecuted person.</rdfs:comment>
        <rdfs:comment xml:lang="en">The name of a BZK applicant can occur on diffent cards.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk applicant</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010">
        <rdfs:subClassOf rdf:resource="https://personsincontext.org/model#PersonObservation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010014"/>
                <owl:someValuesFrom rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">TODO: move to skos:definition

A BZK persecutee is a person who was recorded as a persecutee on a BZK card.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk persecutee</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">TODO: move to description

A digitised BZK Card refers to a scanned version of the corresponding physical BZK card.</rdfs:comment>
        <rdfs:label xml:lang="en">digitised bzk card</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000245"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
