    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#Record"/>
        <rdfs:comment>TODO: move to skos:defintion

A BZK Index Card, or simply a BZK Card, is a document used to initiate the compensation process.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk card</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003 -->

    <owl:Class rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:comment xml:lang="en">A BZK number is not unique, viz., the same number can occur on different BZK Cards issued by different compensation offices.</rdfs:comment>
        <rdfs:comment xml:lang="en">TODO: move to skos:definition 

A BZK number is an identifier of a BZK Card.</rdfs:comment>
        <rdfs:label xml:lang="en">bzk number</rdfs:label>
    </owl:Class>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0000006 -->

