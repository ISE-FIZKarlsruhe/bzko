<?xml version="1.0"?>
<rdf:RDF xmlns="https://bzk.fiz-karlsruhe.de/ontology/bzk/components/imports-edit.owl/"
     xml:base="https://bzk.fiz-karlsruhe.de/ontology/bzk/components/imports-edit.owl/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="https://bzk.fiz-karlsruhe.de/ontology/bzk/components/imports-edit.owl"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/OMO_0002000 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/OMO_0002000"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013 -->

    <owl:ObjectProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:range rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX participates_in: &lt;http://purl.obolibrary.org/obo/RO_0000056&gt; 
PREFIX realizes: &lt;http://purl.obolibrary.org/obo/BFO_0000055&gt; 
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX applicant_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003&gt; 
PREFIX organization: &lt;http://purl.obolibrary.org/obo/OBI_0000245&gt;
PREFIX CO_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001&gt; 


PREFIX applies_for_compensation_to: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010013&gt;

CONSTRUCT { ?wgm_applicant1  applies_for_compensation_to: ?compen_office1}
WHERE {
   ?wgm_applicant1 a person: .
   ?applicant_role1 a applicant_role: .  
   ?indexing1 a indexing: .
   ?wgm_applicant1 has_role:  ?applicant_role1 .
   ?wgm_applicant1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?applicant_role1 .

   ?compen_office1 a organization: .
   ?CO_role1 a CO_role: .  
  ?compen_office1 has_role:  ?CO_role1 .
   ?compen_office1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?CO_role1 .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">applies for compensation to</rdfs:label>
        <skos:definition xml:lang="en">An applicant applies for compensation for on behalf of a persecuted person to a compensation office.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016 -->

    <owl:ObjectProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:range rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX participates_in: &lt;http://purl.obolibrary.org/obo/RO_0000056&gt; 
PREFIX realizes: &lt;http://purl.obolibrary.org/obo/BFO_0000055&gt; 
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX applicant_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003&gt; 
PREFIX persecutee_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002&gt; 

PREFIX applies_for_compensation_for: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010016&gt; 

CONSTRUCT { ?wgm_applicant1  applies_for_compensation_for: ?persecutee_nazi1}
WHERE {
   ?wgm_applicant1 a person: .
   ?applicant_role1 a applicant_role: .  
   ?wgm_applicant1 has_role:  ?applicant_role1 .
   ?indexing1 a indexing: .
   ?wgm_applicant1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?applicant_role1 .

   ?persecutee_nazi1 a person: .
   ?persecutee_role1 a persecutee_role: .  
   ?persecutee_nazi1 has_role:  ?persecutee_role1 .
   ?persecutee_nazi1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?persecutee_role1 .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">applies for compensation for</rdfs:label>
        <skos:definition xml:lang="en">An applicant applies for compensation on behalf of at least one persecuted person.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010024 -->

    <owl:ObjectProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010024">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
        <rdfs:range rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX organization: &lt;http://purl.obolibrary.org/obo/OBI_0000245&gt; 
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX realized_in: &lt;http://purl.obolibrary.org/obo/BFO_0000054&gt; 
PREFIX participates_in: &lt;http://purl.obolibrary.org/obo/RO_0000056&gt; 
PREFIX CO_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001&gt; 
PREFIX bzk_card: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002&gt; 

PREFIX issues: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010024&gt; 

CONSTRUCT {?compen_office1 issues: ?bzk_card1 }  
WHERE {
   ?compen_office1 a organization: .
   ?indexing1 a indexing: .
   ?CO_role1 a CO_role: .
   ?bzk_card1 a bzk_card: .
   ?compen_office1 has_role:  ?CO_role1  .
   ?CO_role1 realized_in: ?indexing1 .
   ?compen_office1 participates_in: ?indexing1 .
   ?bzk_card1 participates_in: ?indexing1 .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">issues</rdfs:label>
        <skos:definition xml:lang="en">A compensation office issues compensation-related documents, including BZK index cards.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2006/time#inXSDDate -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDDate"/>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX IAO: &lt;http://purl.obolibrary.org/obo/IAO_&gt; .

PREFIX denotes: &lt;http://purl.obolibrary.org/obo/IAO_0000219&gt;
PREFIX labeled: &lt;http://www.w3.org/2000/01/rdf-schema#label&gt;
PREFIX bzk_card: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002&gt;
PREFIX bzk_number: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003&gt;

PREFIX has_bzk_number: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020&gt; 

CONSTRUCT {
  ?bzk_card1 has_bzk_number: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_number1 a bzk_number: .
  ?bzk_number1 denotes: ?bzk_card1 .
  ?bzk_number1 labeled: ?label .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">has bzk number</rdfs:label>
        <skos:definition>A BZK index card includes a BZK number, a Federal Central Register number used to track compensation claims. This data property links a BZK card to its identifier.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX denotedBy: &lt;http://purl.obolibrary.org/obo/IAO_0000235&gt;
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX participates_in: &lt;http://purl.obolibrary.org/obo/RO_0000056&gt; 
PREFIX realizes: &lt;http://purl.obolibrary.org/obo/BFO_0000055&gt; 
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX applicant_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003&gt; 
PREFIX persecutee_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002&gt; 
PREFIX givenName: &lt;http://purl.obolibrary.org/obo/IAO_0020016&gt;
PREFIX labeled: &lt;http://www.w3.org/2000/01/rdf-schema#label&gt;

PREFIX has_given_name: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021&gt; 

CONSTRUCT { ?wgm_agent has_given_name: ?label}
WHERE {
   ?wgm_applicant1 a person: .
   ?applicant_role1 a applicant_role: .  
   ?indexing1 a indexing: .
   ?indexing2 a indexing: .
   ?wgm_applicant1 has_role:  ?applicant_role1 .
   ?wgm_applicant1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?applicant_role1 .

   ?persecutee_nazi1 a person: .
   ?persecutee_role1 a persecutee_role: .  
   ?persecutee_nazi1 has_role:  ?persecutee_role1 .
   ?persecutee_nazi1 participates_in: ?indexing1 | ?indexing2 .
   ?indexing1 | ?indexing2 realizes: ?persecutee_role1 .

   ?wgm_agent a wgm_applicant1: |  persecutee_nazi1: .
   ?givenName1 a givenName: .
   ?wgm_agent denotedBy: ?givenName1: .
   ?givenName1 labeled: ?label: .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">has given name</rdfs:label>
        <skos:definition xml:lang="en">This data property links a person to their given (first) name.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010022">
        <rdfs:subPropertyOf rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021"/>
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:label xml:lang="en">has alternative given name</rdfs:label>
        <skos:definition>This data property links a person to a given name that has been altered or rendered in a German or Latin form.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX is_about: &lt;http://purl.obolibrary.org/obo/IAO_0000136&gt;
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX participates_in: &lt;http://purl.obolibrary.org/obo/RO_0000056&gt; 
PREFIX realizes: &lt;http://purl.obolibrary.org/obo/BFO_0000055&gt; 
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX persecutee_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002&gt; 
PREFIX lastResidentialAdd: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006&gt;
PREFIX labeled: &lt;http://www.w3.org/2000/01/rdf-schema#label&gt;

PREFIX has_last_residen_add: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025&gt; 

CONSTRUCT { ?persecutee_nazi1 has_last_residen_add: ?label}
WHERE {
?persecutee_nazi1 a person: .
?persecutee_role1 a persecutee_role: . 
?indexing1 a indexing: . 
?persecutee_nazi1 has_role:  ?persecutee_role1 .
?persecutee_nazi1 participates_in: ?indexing1 .
?indexing1 realizes: ?persecutee_role1 .

?lastResidentialAdd1 a lastResidentialAdd: .
?lastResidentialAdd1 is_about: ?persecutee_nazi1: .
?lastResidentialAdd1 labeled: ?label: .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">has last residential address</rdfs:label>
        <skos:definition xml:lang="en">In BZKO, this data property links a person who either left Germany or died before the compensation process to their the last known address.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX labeled: &lt;http://www.w3.org/2000/01/rdf-schema#label&gt;
PREFIX bzk_card: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002&gt;
PREFIX bzk_layout: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004&gt;
PREFIX is_about: &lt;http://purl.obolibrary.org/obo/IAO_0000136&gt;

PREFIX has_bzk_layout: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026&gt;

CONSTRUCT {
  ?bzk_card1 has_bzk_layout: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_layout1 a bzk_layout: .
  ?bzk_layout1 is_about: ?bzk_card1 .
  ?bzk_layout1 labeled: ?label .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">has layout type</rdfs:label>
        <skos:definition xml:lang="en">This data properry links a BZK index card to its layout type, which is determined by experts at the Federal State Archive.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010027 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010027">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010012"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX denotedBy: &lt;http://purl.obolibrary.org/obo/IAO_0000235&gt;
PREFIX organization: &lt;http://purl.obolibrary.org/obo/OBI_0000245&gt; 
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX realized_in: &lt;http://purl.obolibrary.org/obo/BFO_0000054&gt; 
PREFIX participates_in: &lt;http://purl.obolibrary.org/obo/RO_0000056&gt; 
PREFIX CO_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001&gt; 
PREFIX compOffiName: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005&gt;
PREFIX labeled: &lt;http://www.w3.org/2000/01/rdf-schema#label&gt;

PREFIX has_compen_off_name: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010027&gt; 
CONSTRUCT { ?compen_office1 has_compen_off_name: ?label}
WHERE {
   ?compen_office1 a organization: .
   ?indexing1 a indexing: .
   ?CO_role1 a CO_role: .
   ?compen_office1 has_role:  ?CO_role1  .
   ?CO_role1 realized_in: ?indexing1 .
   ?compen_office1 participates_in: ?indexing1 .

   ?compOffiName1 a compOffiName: .
   ?compen_office1 denotedBy: ?compOffiName1: .
   ?compOffiName1 labeled: ?label: .
}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">has compensation office name</rdfs:label>
        <skos:definition xml:lang="en">This property links a compensation office to its name.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010028 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010028">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:label xml:lang="en">has birthplace</rdfs:label>
        <skos:definition xml:lang="en">This data property links a person to the place where they were born.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010029 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010029">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <obo:OMO_0002000>PREFIX owl: &lt;http://www.w3.org/2002/07/owl#&gt; 
PREFIX indexing: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000&gt;  
PREFIX has_role: &lt;http://purl.obolibrary.org/obo/RO_0000087&gt; 
PREFIX has_participant: &lt;http://purl.obolibrary.org/obo/RO_0000057&gt; 
PREFIX realizes: &lt;http://purl.obolibrary.org/obo/BFO_0000055&gt; 
PREFIX located_in &lt;http://purl.obolibrary.org/obo/RO_0001025&gt;
PREFIX person: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004&gt; 
PREFIX persecutee_role: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002&gt; 
PREFIX deathProcessBound: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009&gt; 
PREFIX place: &lt;https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005&gt;
PREFIX environs: &lt;http://purl.obolibrary.org/obo/BFO_0000183&gt;
PREFIX labeled: &lt;http://www.w3.org/2000/01/rdf-schema#label&gt;

PREFIX has_deathplace: &lt;https://bzk.fiz-karlsruhe.de/ontology/BZK_0010029&gt; 
CONSTRUCT { ?persecutee_nazi1 has_deathplace: ?label}
WHERE {
?persecutee_nazi1 a person: .
?persecutee_role1 a persecutee_role: . 
?indexing1 a indexing: . 

?persecutee_nazi1 has_role:  ?persecutee_role1 .
?persecutee_nazi1 participates_in: ?indexing1 .
?indexing1 realizes: ?persecutee_role1 .

?deathProcessBound1 a deathProcessBound: .
?deathProcessBound1 has_participant: ?persecutee_nazi1 .
?deathplace1 a place: .
?deathplace1 environs: ?deathProcessBound1 . 
?persecutee_nazi1 located_in: ?deathplace1 .
?deathplace1 labeled: ?label: .

}</obo:OMO_0002000>
        <rdfs:label xml:lang="en">has deathplace</rdfs:label>
        <skos:definition xml:lang="en">This data property links a person to the place where they were died.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://bzk.fiz-karlsruhe.de/ontology/BZK_0010121 -->

    <owl:DatatypeProperty rdf:about="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010121">
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0000013"/>
        <rdfs:domain rdf:resource="https://bzk.fiz-karlsruhe.de/ontology/BZK_0010010"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:label xml:lang="en">has family name</rdfs:label>
        <skos:definition xml:lang="en">This property links a person to their family (last) name.</skos:definition>
    </owl:DatatypeProperty>
    


