# Data Property: :BZK_0010029 (has deathplace)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010029 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX has_participant: <http://purl.obolibrary.org/obo/RO_0000057> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX located_in <http://purl.obolibrary.org/obo/RO_0001025>
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 
PREFIX deathProcessBound: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009> 
PREFIX place: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005>
PREFIX environs: <http://purl.obolibrary.org/obo/BFO_0000183>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_deathplace: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010029> 
CONSTRUCT { ?persecutee_nazi1 has_deathplace: ?label}
WHERE {
?persecutee_nazi1 a person: .
?persecutee_role1 a persecutee_role: . 
?indexing1 a indexing: . 

?persecutee_nazi1 has_role:  ?persecutee_role1 .
?persecutee_nazi1 participates_in: ?indexing1 .
?indexing1 realizes: ?persecutee_role1 .

?deathProcessBound1 a deathProcessBound: .
?deathProcessBound1 has_participant: ?persecutee_nazi1 .
?deathplace1 a place: .
?deathplace1 environs: ?deathProcessBound1 . 
?persecutee_nazi1 located_in: ?deathplace1 .
?deathplace1 labeled: ?label: .

}")
AnnotationAssertion(rdfs:label :BZK_0010029 "has deathplace"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010029 "This data property links a person to the place where they were died."@en)
DataPropertyDomain(:BZK_0010029 :BZK_0000013)
DataPropertyDomain(:BZK_0010029 :BZK_0010010)
DataPropertyRange(:BZK_0010029 rdfs:Literal)

# Data Property: :BZK_0010121 (has family name)

AnnotationAssertion(rdfs:label :BZK_0010121 "has family name"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010121 "This property links a person to their family (last) name."@en)
DataPropertyDomain(:BZK_0010121 :BZK_0000013)
DataPropertyDomain(:BZK_0010121 :BZK_0010010)
DataPropertyRange(:BZK_0010121 rdfs:Literal)

# Data Property: :BZK_0010122 (has alternative family name)

AnnotationAssertion(rdfs:label :BZK_0010122 "has alternative family name"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010122 "This data property links a person to a family name that has been altered or rendered in a German or Latin form."@en)
SubDataPropertyOf(:BZK_0010122 :BZK_0010121)
DataPropertyDomain(:BZK_0010122 :BZK_0000013)
DataPropertyDomain(:BZK_0010122 :BZK_0010010)
DataPropertyRange(:BZK_0010122 rdfs:Literal)

# Data Property: :BZK_0010123 (has birth name)

AnnotationAssertion(rdfs:comment :BZK_0010123 "Same as \"maiden name\""@en)
AnnotationAssertion(rdfs:label :BZK_0010123 "has birth name"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010123 "This property links a woman to the family name she used before marriage."@en)
SubDataPropertyOf(:BZK_0010123 :BZK_0010121)
DataPropertyDomain(:BZK_0010123 :BZK_0000013)
DataPropertyDomain(:BZK_0010123 :BZK_0010010)
DataPropertyRange(:BZK_0010123 rdfs:Literal)



