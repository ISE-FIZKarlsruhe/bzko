# Data Property: :BZK_0010020 (has bzk number)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010020 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX IAO: <http://purl.obolibrary.org/obo/IAO_> .

PREFIX denotes: <http://purl.obolibrary.org/obo/IAO_0000219>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_number: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000003>

PREFIX has_bzk_number: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010020> 

CONSTRUCT {
  ?bzk_card1 has_bzk_number: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_number1 a bzk_number: .
  ?bzk_number1 denotes: ?bzk_card1 .
  ?bzk_number1 labeled: ?label .
}")
AnnotationAssertion(rdfs:label :BZK_0010020 "has bzk number"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010020 "A BZK index card includes a BZK number, a Federal Central Register number used to track compensation claims. This data property links a BZK card to its identifier.")
DataPropertyDomain(:BZK_0010020 :BZK_0000002)
DataPropertyRange(:BZK_0010020 rdfs:Literal)

# Data Property: :BZK_0010021 (has given name)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010021 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX applicant_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010003> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 
PREFIX givenName: <http://purl.obolibrary.org/obo/IAO_0020016>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_given_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010021> 

CONSTRUCT { ?wgm_agent has_given_name: ?label}
WHERE {
   ?wgm_applicant1 a person: .
   ?applicant_role1 a applicant_role: .  
   ?indexing1 a indexing: .
   ?indexing2 a indexing: .
   ?wgm_applicant1 has_role:  ?applicant_role1 .
   ?wgm_applicant1 participates_in: ?indexing1 .
   ?indexing1 realizes: ?applicant_role1 .

   ?persecutee_nazi1 a person: .
   ?persecutee_role1 a persecutee_role: .  
   ?persecutee_nazi1 has_role:  ?persecutee_role1 .
   ?persecutee_nazi1 participates_in: ?indexing1 | ?indexing2 .
   ?indexing1 | ?indexing2 realizes: ?persecutee_role1 .

   ?wgm_agent a wgm_applicant1: |  persecutee_nazi1: .
   ?givenName1 a givenName: .
   ?wgm_agent denotedBy: ?givenName1: .
   ?givenName1 labeled: ?label: .
}")
AnnotationAssertion(rdfs:label :BZK_0010021 "has given name"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010021 "This data property links a person to their given (first) name."@en)
DataPropertyDomain(:BZK_0010021 :BZK_0000013)
DataPropertyDomain(:BZK_0010021 :BZK_0010010)
DataPropertyRange(:BZK_0010021 rdfs:Literal)

# Data Property: :BZK_0010022 (has alternative given name)

AnnotationAssertion(rdfs:label :BZK_0010022 "has alternative given name"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010022 "This data property links a person to a given name that has been altered or rendered in a German or Latin form.")
SubDataPropertyOf(:BZK_0010022 :BZK_0010021)
DataPropertyDomain(:BZK_0010022 :BZK_0000013)
DataPropertyDomain(:BZK_0010022 :BZK_0010010)
DataPropertyRange(:BZK_0010022 rdfs:Literal)

# Data Property: :BZK_0010025 (has last residential address)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010025 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX realizes: <http://purl.obolibrary.org/obo/BFO_0000055> 
PREFIX person: <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004> 
PREFIX persecutee_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010002> 
PREFIX lastResidentialAdd: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_last_residen_add: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010025> 

CONSTRUCT { ?persecutee_nazi1 has_last_residen_add: ?label}
WHERE {
?persecutee_nazi1 a person: .
?persecutee_role1 a persecutee_role: . 
?indexing1 a indexing: . 
?persecutee_nazi1 has_role:  ?persecutee_role1 .
?persecutee_nazi1 participates_in: ?indexing1 .
?indexing1 realizes: ?persecutee_role1 .

?lastResidentialAdd1 a lastResidentialAdd: .
?lastResidentialAdd1 is_about: ?persecutee_nazi1: .
?lastResidentialAdd1 labeled: ?label: .
}")
AnnotationAssertion(rdfs:label :BZK_0010025 "has last residential address"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010025 "In BZKO, this data property links a person who either left Germany or died before the compensation process to their the last known address."@en)
DataPropertyDomain(:BZK_0010025 :BZK_0010010)
DataPropertyRange(:BZK_0010025 rdfs:Literal)

# Data Property: :BZK_0010026 (has layout type)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010026 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>
PREFIX bzk_card: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0000002>
PREFIX bzk_layout: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010004>
PREFIX is_about: <http://purl.obolibrary.org/obo/IAO_0000136>

PREFIX has_bzk_layout: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010026>

CONSTRUCT {
  ?bzk_card1 has_bzk_layout: ?label .}
WHERE {
  ?bzk_card1 a bzk_card: .
  ?bzk_layout1 a bzk_layout: .
  ?bzk_layout1 is_about: ?bzk_card1 .
  ?bzk_layout1 labeled: ?label .
}")
AnnotationAssertion(rdfs:label :BZK_0010026 "has layout type"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010026 "This data properry links a BZK index card to its layout type, which is determined by experts at the Federal State Archive."@en)
DataPropertyDomain(:BZK_0010026 :BZK_0000002)

# Data Property: :BZK_0010027 (has compensation office name)

AnnotationAssertion(obo:OMO_0002000 :BZK_0010027 "PREFIX owl: <http://www.w3.org/2002/07/owl#> 
PREFIX denotedBy: <http://purl.obolibrary.org/obo/IAO_0000235>
PREFIX organization: <http://purl.obolibrary.org/obo/OBI_0000245> 
PREFIX indexing: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010000>  
PREFIX has_role: <http://purl.obolibrary.org/obo/RO_0000087> 
PREFIX realized_in: <http://purl.obolibrary.org/obo/BFO_0000054> 
PREFIX participates_in: <http://purl.obolibrary.org/obo/RO_0000056> 
PREFIX CO_role: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010001> 
PREFIX compOffiName: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010005>
PREFIX labeled: <http://www.w3.org/2000/01/rdf-schema#label>

PREFIX has_compen_off_name: <https://bzk.fiz-karlsruhe.de/ontology/BZK_0010027> 
CONSTRUCT { ?compen_office1 has_compen_off_name: ?label}
WHERE {
   ?compen_office1 a organization: .
   ?indexing1 a indexing: .
   ?CO_role1 a CO_role: .
   ?compen_office1 has_role:  ?CO_role1  .
   ?CO_role1 realized_in: ?indexing1 .
   ?compen_office1 participates_in: ?indexing1 .

   ?compOffiName1 a compOffiName: .
   ?compen_office1 denotedBy: ?compOffiName1: .
   ?compOffiName1 labeled: ?label: .
}")
AnnotationAssertion(rdfs:label :BZK_0010027 "has compensation office name"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :BZK_0010027 "This property links a compensation office to its name."@en)
DataPropertyDomain(:BZK_0010027 :BZK_0010012)

