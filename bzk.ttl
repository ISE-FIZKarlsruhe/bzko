###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010006
:BZK_0010006 rdf:type owl:Class ;
             rdfs:subClassOf obo:IAO_0000422 ;
             rdfs:comment "This is the last residential address of a person prior to a specified event, such as deportation, migration, relocation, or death." ;
             rdfs:label "last residential address"@en ;
             skos:definition "A last residential address is the postal address of a person's residence at the relevant point in time."@en .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010007
:BZK_0010007 rdf:type owl:Class ;
             rdfs:subClassOf obo:IAO_0020016 ;
             rdfs:comment "An alternative given name is a given(first) name that has been altered, adapted, transliterated, or rendered in a different language form."@en ;
             rdfs:label "alternative given name"@en .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010008
:BZK_0010008 rdf:type owl:Class ;
             rdfs:subClassOf obo:BFO_0000035 ;
             rdfs:label "birth process boundary"@en ;
             skos:definition "A birth process boundary is an instantaneous transition within a birth process that marks the instant at which an organism begins to exist." .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010009
:BZK_0010009 rdf:type owl:Class ;
             rdfs:subClassOf obo:BFO_0000035 ;
             rdfs:label "death process boundary"@en ;
             skos:definition "A death process boundary is an instantaneous transition within a death process that marks the instant at which an organism ceases to exist." .


###  https://bzk.fiz-karlsruhe.de/ontology/BZK_0010011
:BZK_0010011 rdf:type owl:Class ;
             rdfs:subClassOf obo:IAO_0000310 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:IAO_0000136 ;
                               owl:someValuesFrom :BZK_0000002
                             ] ;
             rdfs:comment "All digitised BZK cards are digital versions of physical BZK Cards, but some BZK Cards may not have their scans in the database. For instance, the back of a BZK card may not have been scanned or linked to the front of the card."@en ;
             rdfs:label "digitised bzk card"@en ;
             skos:definition "A digitised BZK Card refers to a scanned version of the corresponding physical BZK card."@en .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000004
ontology:NFDI_0000004 rdf:type owl:Class ;
                      rdfs:subClassOf ontology:NFDI_0000102 ,
                                      [ owl:intersectionOf ( obo:BFO_0000030
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty obo:RO_0000087 ;
                                                               owl:someValuesFrom ontology:NFDI_0000229
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty obo:IAO_0000235 ;
                                        owl:someValuesFrom obo:IAO_0020016
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty obo:IAO_0000235 ;
                                        owl:someValuesFrom obo:IAO_0020017
                                      ] ;
                      rdfs:label "person"@en ;
                      skos:definition "An object that represents a single human individual."@en ;
                      skos:editorialNote "2024-03-24. Sasha Bruns - the class is not mapped to NCBITaxon_9606 (homo sapiens) due to different scope of the ontologies. \"Person\" in nfdicore represents entities with specific roles, responsibilities, and attributes within an organization, and is not limited to its biological characteristics."@en ;
                      skos:example "Harald Sack, Tabea Tietz, Sasha Bruns, Etienne Posthumus" .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000005
ontology:NFDI_0000005 rdf:type owl:Class ;
                      rdfs:subClassOf obo:BFO_0000029 ;
                      rdfs:label "place"@en ;
                      skos:definition "A site that refers to geographical locations, such as cities, countries, landmarks, and natural environments."@en ;
                      skos:editorialNote "A spatial region, e.g. country, city or district."@en ;
                      skos:example "Hessen, Berlin, Schweiz" ;
                      ontology:NFDI_0010013 "Issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/75" .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000102
ontology:NFDI_0000102 rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( obo:BFO_0000004
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty obo:RO_0000087 ;
                                                                   owl:someValuesFrom ontology:NFDI_0000229
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf obo:BFO_0000004 ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty obo:RO_0000087 ;
                                        owl:someValuesFrom ontology:NFDI_0000229
                                      ] ;
                      rdfs:label "agent"@en ;
                      skos:definition "An independent continuant that acts autonomously and is entrusted with the authority to represent, negotiate, or act on behalf of another agent."@en ;
                      skos:editorialNote "A class that represents entities that are capable of autonomous actions, decision-making, or interaction within a given environment, e.g. persons or organizations."@en ;
                      skos:example "Torsten Schrade, Linnaea Söhn, Academy of Sciences and Literature Mainz"@en .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000106
ontology:NFDI_0000106 rdf:type owl:Class ;
                      rdfs:subClassOf ontology:NFDI_0000005 ;
                      rdfs:label "city"@en ;
                      skos:definition "A place that refers to a densely populated urban area."@en ;
                      skos:editorialNote "A city or a town where the thing is located."@en ;
                      skos:example "Berlin, Hannover, Kyiv"@en .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000119
ontology:NFDI_0000119 rdf:type owl:Class ;
                      rdfs:subClassOf ontology:NFDI_0000005 ;
                      rdfs:label "country"@en ;
                      skos:definition "A place that refers to a defined geographical area distinguished by its territorial boundaries, governance structure, and sovereignty."@en ;
                      skos:editorialNote "A country where the thing is located."@en .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000134
ontology:NFDI_0000134 rdf:type owl:Class ;
                      rdfs:subClassOf ontology:NFDI_0000005 ;
                      rdfs:label "federal state"@en ;
                      skos:definition "A place that refers to a geographical territory forming part of a country."@en ;
                      skos:editorialNote "A federal state where the thing is located."@en ;
                      skos:example "Sachsen, Berlin"@de .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000229
ontology:NFDI_0000229 rdf:type owl:Class ;
                      rdfs:subClassOf [ owl:intersectionOf ( obo:BFO_0000023
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty obo:RO_0000081 ;
                                                               owl:someValuesFrom ontology:NFDI_0000102
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                      rdfs:label "agent role"@en ;
                      skos:definition "Role of an independent continuant that is realized through an agent's actions, enabling the agent to perform specific functions or achieve particular outcomes within a system or context."@en .


###  https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001041
ontology:NFDI_0001041 rdf:type owl:Class ;
                      rdfs:subClassOf obo:IAO_0020000 ;
                      rdfs:isDefinedBy "http://purl.obolibrary.org/obo/IAO_0000646" ;
                      rdfs:label "postal code"@en ;
                      skos:definition "An identifier that denotes some postal delivery route, some aggregate of postal delivery routes or a geographical region and was created for the purpose of sorting and delivering mail." .


#################################################################
#    Individuals
